# --- Database ---
DATABASE_URL=postgresql+asyncpg://dental:dental@localhost:5432/dental_clinic
DATABASE_URL_SYNC=postgresql+psycopg2://dental:dental@localhost:5432/dental_clinic
DATABASE_URL_PSYCOPG=postgresql://dental:dental@localhost:5432/dental_clinic

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL_FAST=claude-haiku-4-5-20251001
LLM_MODEL_ESCALATION=claude-sonnet-4-6

# --- Embeddings ---
VOYAGE_API_KEY=pa-...
EMBEDDING_MODEL=voyage-3.5-lite
EMBEDDING_DIM=512

# --- Sarvam AI (STT/TTS/Translate) ---
SARVAM_API_KEY=sk_...

# --- LiveKit ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Reminders / messaging ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1...

# --- Auth ---
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
DEFAULT_CLINIC_TIMEZONE=Asia/Kolkata
CORS_ORIGINS=["http://localhost:3000"]

# --- LangSmith (optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=dental-clinic-agent
